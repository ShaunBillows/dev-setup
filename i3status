general {
   colors = true
   interval = 5
}

order += "volume master"
order += "wireless _first_"
order += "battery all"
order += "load"
order += "memory"
order += "tztime local"

volume master {
   format = " MUTE"
   device = "default"
   mixer = "Master"
   mixer_idx = 0
}

wireless _first_ {
   format_up = "W: (%quality at %essid) %ip"
   format_down = "W: down"
}

battery all {
   format = "BAT %percentage %remaining"
}

load {
   format = "CPU %1min"
}

memory {
   format = "%used/%total"
}

tztime local {
   format = "%Y-%m-%d %H:%M:%S"
}

