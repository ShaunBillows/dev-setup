general {
    colors = true
    interval = 5
    separator = ""
}

order += "volume master"
order += "cpu_usage"
order += "cpu_temperature 0"
order += "memory"
order += "wireless wlp0s20f3"
order += "battery all"
order += "tztime local"

volume master {
    format = "♪ %volume"
    format_muted = "♪ MUTE"
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}

cpu_usage {
    format = "💻 %usage"
    max_threshold = 75
}

cpu_temperature 0 {
    format = "🌡️%degrees°C"
    max_threshold = 75
}

memory {
    format = "💾 %percentage_used"
    threshold_critical = "2G"
}

wireless wlp0s20f3 {
    format_up = "🌐%quality"
    format_down=""
    color_good = "#eceff4"
    color_degraded = "#d08770"
    color_bad = "#bf616a"
}

battery all {
    format = "⚡ %percentage"
    low_threshold = 20
    threshold_type = "percentage"
}

tztime local {
    format = "📅 %Y-%m-%d 🕐 %H:%M:%S"
}

